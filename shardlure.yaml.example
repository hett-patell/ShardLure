data_dir: /var/lib/shardlure

admin_ips:
  - 100.x.x.x   # your Tailscale IP or admin workstation

ssh:
  admin_port: 2222
  honeypot_port: 22

dashboard:
  port: 8080
  # Change these to your VPS/operator location for the globe origin.
  home_lat: 19.0760
  home_lon: 72.8777
  home_city: Mumbai
  home_country: India
  home_cc: IN

journal:
  unit: ssh

cowrie:
  home: /var/lib/shardlure/cowrie
  json_log: /var/lib/shardlure/cowrie/var/log/cowrie/cowrie.json

# Quarantine-fetch URLs from attacker commands; archive Cowrie downloads.
capture:
  enabled: true
  evidence_dir: /var/lib/shardlure/evidence
  quarantine_fetch: true
  max_bytes: 52428800
  timeout_sec: 45

geoip:
  # Required for globe arcs / country stats (resolves attacker IPs).
  enabled: true
  insecure_http: true
  # mmdb (offline GeoLite2 lookup) is parsed but NOT implemented yet —
  # see the README roadmap. Setting it has no effect today.
  # mmdb: /var/lib/shardlure/GeoLite2-City.mmdb

# Outbound threat-intel sharing. Each destination is opt-in; leaving
# api_key empty disables it. See the "Threat Intel Sharing" README
# section for the full submission policy and dry-run workflow.
intel:
  bazaar:
    # Sign up at https://auth.abuse.ch/ and paste your Auth-Key here.
    api_key: ""
    # Tags appended to every uploaded sample (in addition to the
    # per-sample auto-tags from the classifier).
    tags: ["shardlure", "honeypot"]
    # Hard client-side size cap. abuse.ch enforces its own server
    # cap; this is a safety rail against accidentally uploading a
    # cowrie SFTP capture that turns out to be a 4 GiB dump.
    max_bytes: 33554432   # 32 MiB
    # Abuse.ch fair-use: do not upload samples older than 10 days.
    # The share subcommand filters artifacts by this window unless
    # --since or --sha overrides it.
    freshness_days: 10
  abuseipdb:
    # Outbound REPORTING of confirmed brute-forcers to AbuseIPDB (the
    # give-back to the community feed). OFF by default. Enrichment /check
    # reads are unaffected by this and always work when the key is set.
    #
    # Reporting requires BOTH report_enabled: true AND the API key in the
    # SHARDLURE_ABUSEIPDB_KEY env var (reused from enrichment /check — the
    # key is never a config field). Never reports admin or private/reserved
    # IPs, and only reports actors that pass the vetting gate (confirmed
    # brute-force playbook + probe score + event/user floor).
    report_enabled: false
    # AbuseIPDB category IDs attached to every report. 18=Brute-Force, 22=SSH.
    # See https://www.abuseipdb.com/categories
    categories: [18, 22]
    # Minimum actor ProbeScore (0-100) to report. 60 = high-confidence only.
    min_probe_score: 60
    # Hours before a reported IP may be reported again. AbuseIPDB permits
    # re-reporting after 15 min; 24h keeps us well within fair use.
    rewindow_hours: 24
    # Optional operator suffix appended to the generated report comment. The
    # generated comment carries NOTHING identifying the honeypot host/session.
    comment: ""
