#!/bin/bash
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DATA_DIR="${SHARDLURE_DATA:-/var/lib/shardlure}"
CONFIG_FILE="$DATA_DIR/shardlure.yaml"
COWRIE_HOME="$DATA_DIR/cowrie"
COWRIE_LOG="$COWRIE_HOME/var/log/cowrie/cowrie.json"
COWRIE_USER="${COWRIE_USER:-cowrie}"
BIN_DIR="/usr/local/bin"
SYSTEMD_DIR="/etc/systemd/system"

HONEYPOT_PORT=22
ADMIN_SSH_PORT=2222
DASHBOARD_PORT=8080
ADMIN_IPS=()

log() { printf '[shardlure] %s\n' "$*"; }
die() { printf '[shardlure] error: %s\n' "$*" >&2; exit 1; }

need_root() {
  if [ "$(id -u)" -ne 0 ]; then
    die "run as root: sudo bash scripts/shardlure run"
  fi
}

detect_pkg_manager() {
  if command -v apt-get >/dev/null 2>&1; then echo apt; return; fi
  if command -v dnf >/dev/null 2>&1; then echo dnf; return; fi
  if command -v yum >/dev/null 2>&1; then echo yum; return; fi
  if command -v pacman >/dev/null 2>&1; then echo pacman; return; fi
  if command -v zypper >/dev/null 2>&1; then echo zypper; return; fi
  echo unknown
}

install_deps() {
  local pm arch
  pm="$(detect_pkg_manager)"
  arch="$(uname -m)"
  log "installing dependencies via $pm ($arch)"
  case "$pm" in
    apt)
      if [ "$arch" = "aarch64" ] || [ "$arch" = "arm64" ]; then
        if grep -r "binary-amd64" /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null | grep -q .; then
          log "warning: arm64 host has amd64 apt entries; apt update may warn (continuing)"
        fi
      fi
      apt-get update -qq || log "apt update had errors; using existing package indexes"
      DEBIAN_FRONTEND=noninteractive apt-get install -y \
        git python3 python3-venv python3-dev python3-pip \
        build-essential libssl-dev libffi-dev authbind \
        curl ca-certificates golang-go || true
      ;;
    dnf|yum)
      "$pm" install -y git python3 python3-pip python3-devel \
        gcc openssl-devel libffi-devel authbind curl ca-certificates golang || true
      ;;
    pacman)
      pacman -Sy --noconfirm git python python-pip base-devel openssl libffi authbind curl go || true
      ;;
    *)
      log "unknown package manager; ensure git, python3, venv, authbind, go are installed"
      ;;
  esac

  # The package-manager calls above tolerate errors (|| true) so apt warnings on
  # mismatched-arch repos don't abort. But if an *essential* tool is genuinely
  # missing afterward, fail here with a clear message rather than at a confusing
  # downstream step (e.g. an opaque `go build` failure).
  local missing=()
  for tool in git python3 go; do
    command -v "$tool" >/dev/null 2>&1 || missing+=("$tool")
  done
  if [ "${#missing[@]}" -gt 0 ]; then
    die "required tools missing after dependency install: ${missing[*]}. Install them and re-run."
  fi
}

# valid_port echoes the port if it is an integer 1-65535, else dies. This is a
# security control, not just UX: the ports are interpolated verbatim into the
# sshd drop-in, systemd units, and a Cowrie config heredoc, so an unvalidated
# value (e.g. "22\nPermitRootLogin yes") could inject directives.
valid_port() {
  local p="$1" name="$2"
  case "$p" in
    ''|*[!0-9]*) die "$name must be an integer 1-65535, got: $p" ;;
  esac
  if [ "$p" -lt 1 ] || [ "$p" -gt 65535 ]; then
    die "$name must be in range 1-65535, got: $p"
  fi
  printf '%s' "$p"
}

prompt_config() {
  echo
  echo "ShardLure honeypot setup"
  echo "------------------------"
  echo "Real SSH will move to a private admin port (key-only)."
  echo "Cowrie honeypot will listen on the bait port for attackers."
  echo

  read -r -p "Honeypot SSH port attackers should hit [22]: " _hp
  HONEYPOT_PORT="$(valid_port "${_hp:-22}" 'honeypot port')"

  read -r -p "Admin SSH port for your key-based login [2222]: " _ap
  ADMIN_SSH_PORT="$(valid_port "${_ap:-2222}" 'admin port')"

  read -r -p "Dashboard port [8080]: " _dp
  DASHBOARD_PORT="$(valid_port "${_dp:-8080}" 'dashboard port')"

  if [ "$HONEYPOT_PORT" = "$ADMIN_SSH_PORT" ]; then
    die "honeypot port and admin port must differ"
  fi
  if [ "$DASHBOARD_PORT" = "$HONEYPOT_PORT" ] || [ "$DASHBOARD_PORT" = "$ADMIN_SSH_PORT" ]; then
    die "dashboard port must differ from the SSH ports"
  fi
}

collect_admin_ips() {
  ADMIN_IPS=()
  if command -v tailscale >/dev/null 2>&1; then
    local tsip
    tsip="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
    if [ -n "$tsip" ]; then
      ADMIN_IPS+=("$tsip")
      log "detected tailscale admin IP: $tsip"
    fi
  fi
  if [ -n "${SSH_CONNECTION:-}" ]; then
    local src
    src="${SSH_CONNECTION%% *}"
    if [ -n "$src" ] && [ "$src" != "127.0.0.1" ]; then
      ADMIN_IPS+=("$src")
      log "detected current SSH client IP: $src"
    fi
  fi
  read -r -p "Extra admin IPs to ignore (comma-separated, optional): " _extra
  if [ -n "$_extra" ]; then
    IFS=',' read -r -a _parts <<< "$_extra"
    for ip in "${_parts[@]}"; do
      ip="$(echo "$ip" | tr -d ' ')"
      [ -n "$ip" ] && ADMIN_IPS+=("$ip")
    done
  fi
}

ensure_admin_ssh_keys() {
  local keys_found=0
  for home in /root /home/*; do
    [ -d "$home/.ssh" ] || continue
    if [ -s "$home/.ssh/authorized_keys" ]; then
      keys_found=1
    fi
  done
  if [ "$keys_found" -eq 0 ]; then
    die "no authorized_keys found. Add your SSH public key before moving real SSH off port 22."
  fi
}

migrate_sshd() {
  log "moving real SSH to port $ADMIN_SSH_PORT (key-only)"
  ensure_admin_ssh_keys

  mkdir -p /etc/ssh/sshd_config.d
  if [ -f /etc/ssh/sshd_config ] && ! grep -q 'shardlure-bak' /etc/ssh/sshd_config; then
    cp /etc/ssh/sshd_config /etc/ssh/sshd_config.shardlure-bak
  fi
  if grep -q '^Port ' /etc/ssh/sshd_config; then
    sed -i 's/^Port /#Port /' /etc/ssh/sshd_config
  fi

  cat > /etc/ssh/sshd_config.d/99-shardlure-admin.conf <<EOF
# Managed by ShardLure
Port ${ADMIN_SSH_PORT}
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes
PermitRootLogin prohibit-password
EOF

  sshd -t
  systemctl reload ssh || systemctl reload sshd
  log "real SSH now on port $ADMIN_SSH_PORT"
}

# verify_admin_ssh_gate pauses after the SSH move so the operator proves they
# can still log in on the new admin port BEFORE the install proceeds (and before
# they close this session). Mirrors the Python installer's gate; without it a
# bad admin-port config locks the user out.
verify_admin_ssh_gate() {
  local user host conn
  user="${SUDO_USER:-$(whoami)}"
  host="<this-server-ip>"
  conn="${SSH_CONNECTION:-}"
  if [ -n "$conn" ]; then
    host="$(printf '%s' "$conn" | awk '{print $3}')"
  fi
  echo
  echo "  -------------------------------------------------------------"
  echo "  Real SSH now listens on port $ADMIN_SSH_PORT (key-only)."
  echo "  >>> In a SEPARATE terminal, RIGHT NOW, confirm you can log in:"
  echo "        ssh -p $ADMIN_SSH_PORT $user@$host"
  echo "  Do NOT close this session until that works."
  echo "  -------------------------------------------------------------"
  while true; do
    read -r -p "  Did 'ssh -p $ADMIN_SSH_PORT' succeed in the other terminal? [yes/abort]: " _ans
    case "$_ans" in
      yes|y|Y) return 0 ;;
      abort|a|no|n|N) die "aborted at SSH-verify gate. Real SSH is on the new port; fix access before re-running." ;;
      *) echo "  Type 'yes' once you've confirmed login, or 'abort' to stop." ;;
    esac
  done
}

setup_authbind() {
  if [ "$HONEYPOT_PORT" -ge 1024 ]; then
    return
  fi
  log "configuring authbind for port $HONEYPOT_PORT"
  if command -v authbind >/dev/null 2>&1; then
    touch "/etc/authbind/byport/$HONEYPOT_PORT"
    chown "$COWRIE_USER:$COWRIE_USER" "/etc/authbind/byport/$HONEYPOT_PORT"
    chmod 500 "/etc/authbind/byport/$HONEYPOT_PORT"
    return
  fi
  log "authbind not found; applying setcap on python for low port bind"
  setcap cap_net_bind_service=+ep "$COWRIE_HOME/venv/bin/python3" || die "need authbind or setcap to bind honeypot port $HONEYPOT_PORT"
}

ensure_cowrie_user() {
  if ! id "$COWRIE_USER" >/dev/null 2>&1; then
    useradd -r -m -d "/home/$COWRIE_USER" -s /bin/bash "$COWRIE_USER"
  fi
}

install_cowrie() {
  log "installing Cowrie into $COWRIE_HOME"
  mkdir -p "$DATA_DIR"
  if [ ! -d "$COWRIE_HOME/.git" ]; then
    git clone --depth 1 https://github.com/cowrie/cowrie.git "$COWRIE_HOME"
  else
    git -C "$COWRIE_HOME" pull --ff-only || true
  fi

  python3 -m venv "$COWRIE_HOME/venv" || die "failed to create Cowrie virtualenv"
  "$COWRIE_HOME/venv/bin/pip" install --upgrade pip wheel || die "pip install (pip/wheel) failed"
  "$COWRIE_HOME/venv/bin/pip" install -r "$COWRIE_HOME/requirements.txt" \
    || die "pip install of Cowrie requirements failed; Cowrie would be left broken"

  mkdir -p "$COWRIE_HOME/var/log/cowrie" "$COWRIE_HOME/var/lib/cowrie/downloads" "$COWRIE_HOME/etc"
  if [ ! -f "$COWRIE_HOME/etc/cowrie.cfg" ]; then
    cp "$COWRIE_HOME/etc/cowrie.cfg.dist" "$COWRIE_HOME/etc/cowrie.cfg"
  fi

  cat >> "$COWRIE_HOME/etc/cowrie.cfg" <<EOF

[shardlure]
# appended by ShardLure setup
EOF

  # Pass paths/ports through the environment rather than interpolating them
  # into the Python source: a value containing a quote (or worse) would
  # otherwise break or inject into the heredoc.
  COWRIE_HOME="$COWRIE_HOME" HONEYPOT_PORT="$HONEYPOT_PORT" python3 - <<'PY'
import os
from pathlib import Path
home = os.environ["COWRIE_HOME"]
port = os.environ["HONEYPOT_PORT"]
cfg = Path(home) / "etc/cowrie.cfg"
text = cfg.read_text()
block = f"""
[honeypot]
hostname = prod-app-server-01
log_path = {home}/var/log/cowrie
data_path = {home}/var/lib/cowrie
download_path = {home}/var/lib/cowrie/downloads

[output_jsonlog]
enabled = true
logfile = {home}/var/log/cowrie/cowrie.json

[ssh]
listen_endpoints = tcp:{port}:interface=0.0.0.0
"""
# Only append when the sections are actually missing. Previously the write ran
# unconditionally (it sat outside the loop), so the block was appended even
# when every section already existed.
if not all(s in text for s in ("[honeypot]", "[output_jsonlog]", "[ssh]")):
    cfg.write_text(text.rstrip() + "\n" + block)
PY

  chown -R "$COWRIE_USER:$COWRIE_USER" "$COWRIE_HOME"
  setup_authbind
}

build_shardlure() {
  log "building shardlure binary"
  if [ -d "$ROOT" ] && [ -f "$ROOT/go.mod" ]; then
    # Build into a private mktemp file (in the root-owned BIN_DIR, not the
    # world-writable /tmp) to avoid a TOCTOU/symlink race on a predictable path.
    local _tmpbin
    _tmpbin="$(mktemp "$BIN_DIR/.shardlure.XXXXXX")" || die "mktemp failed"
    (cd "$ROOT" && go mod tidy && go build -o "$_tmpbin" ./cmd/shardlure) || { rm -f "$_tmpbin"; die "go build failed"; }
    install -m 0755 "$_tmpbin" "$BIN_DIR/shardlure"
    rm -f "$_tmpbin"
  elif command -v go >/dev/null 2>&1 && [ -f "$ROOT/go.mod" ]; then
    (cd "$ROOT" && go build -o "$BIN_DIR/shardlure" ./cmd/shardlure)
  else
    die "could not build shardlure; install golang or copy a prebuilt binary to $BIN_DIR/shardlure"
  fi
}

write_config() {
  log "writing $CONFIG_FILE"
  mkdir -p "$DATA_DIR"
  {
    echo "data_dir: $DATA_DIR"
    echo "admin_ips:"
    for ip in "${ADMIN_IPS[@]}"; do
      echo "  - $ip"
    done
    echo "ssh:"
    echo "  admin_port: $ADMIN_SSH_PORT"
    echo "  honeypot_port: $HONEYPOT_PORT"
    echo "dashboard:"
    echo "  port: $DASHBOARD_PORT"
    echo "journal:"
    echo "  unit: ssh"
    echo "cowrie:"
    echo "  home: $COWRIE_HOME"
    echo "  json_log: $COWRIE_LOG"
  } > "$CONFIG_FILE"
}

install_services() {
  log "installing systemd services"
  local cowrie_exec
  if [ "$HONEYPOT_PORT" -lt 1024 ] && command -v authbind >/dev/null 2>&1; then
    cowrie_exec="/usr/bin/authbind --deep $COWRIE_HOME/venv/bin/python3 $COWRIE_HOME/bin/cowrie start -n"
  else
    cowrie_exec="$COWRIE_HOME/venv/bin/python3 $COWRIE_HOME/bin/cowrie start -n"
  fi

  cat > "$SYSTEMD_DIR/cowrie.service" <<EOF
[Unit]
Description=Cowrie SSH honeypot (ShardLure)
After=network.target

[Service]
Type=simple
User=$COWRIE_USER
WorkingDirectory=$COWRIE_HOME
ExecStart=$cowrie_exec
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

  cat > "$SYSTEMD_DIR/shardlure-live.service" <<EOF
[Unit]
Description=ShardLure live dashboard + telemetry ingest
After=network.target cowrie.service
Wants=cowrie.service

[Service]
Type=simple
Environment=SHARDLURE_CONFIG=$CONFIG_FILE
ExecStart=$BIN_DIR/shardlure live :$DASHBOARD_PORT --tailscale --cowrie=$COWRIE_LOG
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable cowrie.service shardlure-live.service
  systemctl restart cowrie.service
  sleep 2
  systemctl restart shardlure-live.service
}

open_firewall() {
  if command -v ufw >/dev/null 2>&1 && ufw status | grep -qi active; then
    ufw allow "$HONEYPOT_PORT/tcp" || true
    ufw allow "$ADMIN_SSH_PORT/tcp" || true
    ufw allow "$DASHBOARD_PORT/tcp" || true
  fi
}

print_summary() {
  local tsurl=""
  if command -v tailscale >/dev/null 2>&1; then
    tsurl="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
  fi
  echo
  echo "ShardLure is running"
  echo "===================="
  echo "Honeypot SSH (Cowrie): 0.0.0.0:$HONEYPOT_PORT"
  echo "Admin SSH (real):      0.0.0.0:$ADMIN_SSH_PORT  (key-only)"
  echo "Dashboard:             http://127.0.0.1:$DASHBOARD_PORT"
  if [ -n "$tsurl" ]; then
    echo "Tailscale dashboard:   http://$tsurl:$DASHBOARD_PORT"
  fi
  echo
  echo "IMPORTANT: open a NEW terminal and verify admin SSH before closing this one:"
  echo "  ssh -p $ADMIN_SSH_PORT user@$(hostname -I | awk '{print $1}')"
  echo
  echo "Services:"
  echo "  systemctl status cowrie shardlure-live"
  echo "  journalctl -u shardlure-live -f"
}

cmd_run() {
  need_root
  install_deps
  prompt_config
  collect_admin_ips
  migrate_sshd
  verify_admin_ssh_gate
  ensure_cowrie_user
  install_cowrie
  build_shardlure
  write_config
  open_firewall
  install_services
  print_summary
}

cmd_status() {
  systemctl status cowrie.service shardlure-live.service --no-pager || true
  if [ -x "$BIN_DIR/shardlure" ]; then
    "$BIN_DIR/shardlure" status
  fi
}

cmd_stop() {
  need_root
  systemctl stop shardlure-live.service cowrie.service || true
}

cmd_start() {
  need_root
  systemctl start cowrie.service shardlure-live.service
}

case "${1:-run}" in
  run|setup) cmd_run ;;
  start) cmd_start ;;
  stop) cmd_stop ;;
  status) cmd_status ;;
  *)
    echo "usage: $0 {run|start|stop|status}"
    exit 1
    ;;
esac
