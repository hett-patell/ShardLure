#!/bin/bash
# Compatibility shim. The standalone bash installer was retired: it had
# drifted far behind scripts/shardlure.py — no ssh.socket handling (operator
# lockout risk on socket-activated Ubuntu 22.10+), no interactive SSH key
# onboarding, no sshd rollback on config-test failure, no uninstall/finish
# subcommands — and carried bugs the Python installer had already fixed
# (sshd_config backup clobbering, duplicate cowrie.cfg sections).
# shardlure.py accepts a superset of the old subcommands
# (run|setup|start|stop|status|finish|plant-bait|uninstall).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v python3 >/dev/null 2>&1; then
  echo "[shardlure] error: python3 is required (the bash installer was retired; this shim delegates to shardlure.py)" >&2
  exit 1
fi

exec python3 "$SCRIPT_DIR/shardlure.py" "$@"
