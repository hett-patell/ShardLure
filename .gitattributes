# Force LF + UTF-8 everywhere so editors/transfers can't silently re-encode
# files into UTF-16LE. (See README troubleshooting; this was a repeat issue.)
* text=auto eol=lf working-tree-encoding=UTF-8

# Explicit overrides for clarity and editor hints.
*.go        text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.html      text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
Makefile    text eol=lf
LICENSE     text eol=lf

# Persona bait files are text — they get cat'd by attackers in a fake shell.
install/persona/**          text eol=lf

# Testdata is plain text journal exports.
testdata/**                 text eol=lf
